<Window x:Class="DevCockpit.TaskEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Задача"
        Icon="Assets/WideS.ico"
        Width="760"
        Height="640"
        MinWidth="700"
        MinHeight="580"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent">
    <Border BorderBrush="#2A323D" BorderThickness="1" CornerRadius="12" Background="{StaticResource AppBgBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
                <RowDefinition Height="56" />
            </Grid.RowDefinitions>

            <!-- Шапка с drag + кнопка закрытия -->
            <Border Grid.Row="0" Background="{StaticResource SidebarBrush}"
                    CornerRadius="11,11,0,0"
                    BorderBrush="#1E242C" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right" Content="✕"
                            Width="42" Height="42" Padding="0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource MutedBrush}"
                            FontSize="14" Cursor="Hand"
                            Click="Close_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" Width="42" Height="42" CornerRadius="0,11,0,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#C42B1C" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button DockPanel.Dock="Right" Content="—"
                            Width="42" Height="42" Padding="0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource MutedBrush}"
                            FontSize="16" Cursor="Hand"
                            Click="Minimize_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" Width="42" Height="42">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2A3545" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="Задача" Foreground="{StaticResource TextBrush}"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center" Margin="18,0,0,0" />
                </DockPanel>
            </Border>

            <!-- Контент -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16,24,0">
                <StackPanel>
                    <TextBlock Text="Название задачи" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="TitleBox" Margin="0,0,0,14" />

                    <TextBlock Text="Описание" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="DescriptionBox" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" MinHeight="120" Margin="0,0,0,14" />

                    <TextBlock Text="Контакт" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="ContactNameBox" Margin="0,0,0,14" />

                    <TextBlock Text="Телефон" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="ContactPhoneBox" Margin="0,0,0,14" />

                    <TextBlock Text="Дата и время" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="66" />
                        </Grid.ColumnDefinitions>
                        <DatePicker x:Name="StartDatePicker" Margin="0,0,6,0" />
                        <ComboBox x:Name="StartHourBox" Grid.Column="1" Style="{StaticResource TimeComboBox}" Margin="0,0,6,0" ToolTip="Час" />
                        <ComboBox x:Name="StartMinuteBox" Grid.Column="2" Style="{StaticResource TimeComboBox}" ToolTip="Минуты" />
                    </Grid>

                    <TextBlock Text="Важность" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Button x:Name="GreenImportance"  Width="32" Height="32" Margin="0,0,12,0"
                                Background="#228B22" BorderBrush="Transparent" BorderThickness="2"
                                Click="GreenImportance_Click" ToolTip="Не срочно">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Width="22" Height="22" CornerRadius="11"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" />
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="YellowImportance" Width="32" Height="32" Margin="0,0,12,0"
                                Background="#FF8C00" BorderBrush="Transparent" BorderThickness="2"
                                Click="YellowImportance_Click" ToolTip="Средне">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Width="22" Height="22" CornerRadius="11"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" />
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="RedImportance"    Width="32" Height="32"
                                Background="{StaticResource DangerBrush}"
                                BorderBrush="Transparent" BorderThickness="2"
                                Click="RedImportance_Click" ToolTip="Срочно">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Width="22" Height="22" CornerRadius="11"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" />
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="Повтор" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <ComboBox x:Name="RecurrenceBox" IsEditable="False" Margin="0,0,0,14" />

                    <TextBlock Text="Проект" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <ComboBox x:Name="ProjectBox" IsEditable="False" Margin="0,0,0,14" />
                </StackPanel>
            </ScrollViewer>

            <!-- Нижняя панель с кнопками -->
            <Border Grid.Row="2" Background="{StaticResource SidebarBrush}"
                    CornerRadius="0,0,11,11"
                    BorderBrush="#1E242C" BorderThickness="0,1,0,0">
                <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Click="Save_Click" />
                    <Button Content="Отмена"    Style="{StaticResource GhostButton}"   Click="Cancel_Click" />
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
</Window>
