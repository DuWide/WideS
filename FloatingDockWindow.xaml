<Window x:Class="DevCockpit.FloatingDockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WideS Dock"
        Icon="Assets/WideS.ico"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowDrop="True"
        Background="Transparent">
    <Border x:Name="Root" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource AccentBorderBrush}" BorderThickness="1"
            CornerRadius="10" Padding="10,8"
            MouseLeftButtonDown="Root_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.32" Color="#000000" />
        </Border.Effect>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <!-- Логотип -->
            <Image Source="Assets/WideS.png" Width="22" Height="22" Margin="6,0,10,0" VerticalAlignment="Center" />

            <!-- Быстрые действия -->
            <Button x:Name="TaskButton" Style="{StaticResource DockButton}" Click="Task_Click" ToolTip="Новая задача" />
            <Button x:Name="NoteButton" Style="{StaticResource DockButton}" Click="Note_Click" ToolTip="Новая заметка" />
            <Button x:Name="DropButton" Style="{StaticResource DockButton}" Click="Drop_Click" ToolTip="DropZone — можно перетащить файл на панель" />
            <Button x:Name="OpenButton" Style="{StaticResource DockButton}" Click="Open_Click" ToolTip="Открыть WideS" />
            <Button x:Name="ConnButton" Style="{StaticResource DockButton}" Click="Conn_Click" ToolTip="Подключения" />

            <Popup x:Name="ConnPopup" Placement="Top" StaysOpen="False" AllowsTransparency="True">
                <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource AccentBorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" MinWidth="260">
                    <StackPanel>
                        <TextBlock Text="Подключение" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8" />
                        <ComboBox x:Name="ConnCombo" MinWidth="230" Margin="0,0,0,10" />
                        <WrapPanel>
                            <Button Content="Подключиться" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                    Click="ConnConnect_Click" />
                            <Button Content="Пароль" Style="{StaticResource GhostButton}"
                                    Click="ConnPassword_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- Разделитель -->
            <Border x:Name="MediaSeparator" Width="1" Height="34" Background="{DynamicResource BorderMainBrush}" Margin="8,0,8,0" Visibility="Collapsed" />

            <!-- Мини-плеер -->
            <StackPanel x:Name="MediaPanel" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                <Image x:Name="DockAlbumArt" Width="36" Height="36" Margin="0,0,8,0"
                       Stretch="UniformToFill" Visibility="Collapsed" />
                <StackPanel VerticalAlignment="Center" Margin="0,0,8,0" MaxWidth="200">
                    <TextBlock x:Name="DockNpTitle" Text="" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="DockNpArtist" Text="" FontSize="10"
                               Foreground="{DynamicResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Button x:Name="DockNpPrev" Width="30" Height="30" Style="{StaticResource WindowButton}"
                        Margin="0,0,5,0" ToolTip="Предыдущий" Click="NpPrev_Click" />
                <Button x:Name="DockNpPlay" Width="38" Height="30" Style="{StaticResource WindowButton}"
                        ToolTip="Пауза / Играть" Click="NpPlay_Click" />
                <Button x:Name="DockNpNext" Width="30" Height="30" Style="{StaticResource WindowButton}"
                        Margin="5,0,0,0" ToolTip="Следующий" Click="NpNext_Click" />
            </StackPanel>

            <!-- Закрыть -->
            <Border Width="1" Height="34" Background="{DynamicResource BorderMainBrush}" Margin="8,0,8,0" />
            <Button x:Name="HideButton" Width="30" Height="30" Style="{StaticResource WindowButton}"
                    ToolTip="Скрыть панель (Ctrl+Alt+Space)" Click="Hide_Click" />
        </StackPanel>
    </Border>
</Window>
