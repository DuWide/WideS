<Window x:Class="DevCockpit.GlobalSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Поиск"
        Width="640"
        Height="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent">
    <Border Style="{StaticResource DialogFrame}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Padding="16,14,16,10" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBox x:Name="SearchBox" FontSize="16" MinHeight="36"
                             KeyDown="SearchBox_KeyDown" TextChanged="SearchBox_TextChanged" />
                    <TextBlock Text="Проекты, задачи, заметки, подключения и буфер"
                               Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
            <ListBox x:Name="ResultsList" Grid.Row="1" BorderThickness="0"
                     Background="Transparent" MouseDoubleClick="ResultsList_MouseDoubleClick"
                     KeyDown="ResultsList_KeyDown" />
        </Grid>
    </Border>
</Window>
