<Window x:Class="DevCockpit.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WideS"
        Icon="Assets/WideS.ico"
        Width="520"
        Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown">
    <Border Style="{StaticResource DialogFrame}"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid Background="{DynamicResource AppBgBrush}" Margin="28">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="Assets/WideS.png" Width="62" Height="62" Margin="0,0,0,16" />
                <TextBlock x:Name="WelcomeText"
                           FontFamily="{StaticResource DisplayFont}"
                           FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="500" />
                <TextBlock Text="WideS готов к работе"
                           FontSize="14"
                           Foreground="{DynamicResource MutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,18" />
                <Button Content="Продолжить" Style="{StaticResource PrimaryButton}" Width="170" Height="42" Click="Continue_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
