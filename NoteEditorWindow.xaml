<Window x:Class="DevCockpit.NoteEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заметка"
        Icon="Assets/WideS.ico"
        Width="840"
        Height="680"
        MinWidth="680"
        MinHeight="540"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent">
    <Border BorderBrush="#2A323D" BorderThickness="1" CornerRadius="12" Background="{StaticResource AppBgBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="56" />
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <Border Grid.Row="0" Background="{StaticResource SidebarBrush}"
                    CornerRadius="11,11,0,0"
                    BorderBrush="#1E242C" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right" Content="✕"
                            Width="42" Height="42" Padding="0"
                            Foreground="{StaticResource MutedBrush}"
                            FontSize="14" Cursor="Hand" Click="Cancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" Width="42" Height="42" CornerRadius="0,11,0,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#C42B1C" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button DockPanel.Dock="Right" Content="—"
                            Width="42" Height="42" Padding="0"
                            Foreground="{StaticResource MutedBrush}"
                            FontSize="16" Cursor="Hand" Click="Minimize_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" Width="42" Height="42">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2A3545" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="Заметка" Foreground="{StaticResource TextBrush}"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center" Margin="18,0,0,0" />
                </DockPanel>
            </Border>

            <!-- Мета-поля (заголовок, категория, проект) -->
            <Border Grid.Row="1" Padding="24,14,24,10" Background="{StaticResource AppBgBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="170" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Заголовок" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                        <TextBox x:Name="TitleBox" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Категория" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                        <ComboBox x:Name="CategoryBox" IsEditable="False" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Проект" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                        <ComboBox x:Name="WorkspaceBox" IsEditable="False" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Текст заметки -->
            <Grid Grid.Row="2" Margin="24,0,24,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <CheckBox x:Name="ImportantBox" Content="Важная заметка"
                          Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                <TextBox x:Name="TextBox" Grid.Row="1"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="14" MinHeight="300" />
            </Grid>

            <!-- Кнопки -->
            <Border Grid.Row="3" Background="{StaticResource SidebarBrush}"
                    CornerRadius="0,0,11,11"
                    BorderBrush="#1E242C" BorderThickness="0,1,0,0">
                <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button Content="Обнаружить подключения" Style="{StaticResource GhostButton}" Click="DetectConnections_Click" />
                    <Button Content="Копировать" Style="{StaticResource GhostButton}"   Click="Copy_Click" />
                    <Button Content="Сохранить"  Style="{StaticResource PrimaryButton}" Click="Save_Click" />
                    <Button Content="Отмена"     Style="{StaticResource GhostButton}"   Click="Cancel_Click" />
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
</Window>
