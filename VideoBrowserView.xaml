<UserControl x:Class="DevCockpit.VideoBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             MinHeight="620">
    <Grid x:Name="RootGrid">
        <Grid x:Name="CatalogScreen">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox"
                         MinHeight="38"
                         Padding="10,7"
                         KeyDown="SearchBox_KeyDown"
                         ToolTip="Название аниме или сериала" />
                <Button Grid.Column="1"
                        Content="Найти"
                        Style="{StaticResource PrimaryButton}"
                        Margin="8,0,0,0"
                        MinWidth="88"
                        Click="Search_Click" />
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="CatalogTabButton"
                        Content="Каталог"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="110"
                        Margin="0,0,8,0"
                        Click="CatalogTab_Click" />
                <Button x:Name="FavoritesTabButton"
                        Content="Избранное"
                        Style="{StaticResource GhostButton}"
                        MinWidth="110"
                        Margin="0,0,8,0"
                        Click="FavoritesTab_Click" />
                <Button x:Name="HistoryTabButton"
                        Content="История"
                        Style="{StaticResource GhostButton}"
                        MinWidth="110"
                        Margin="0,0,8,0"
                        Click="HistoryTab_Click" />
                <Button x:Name="SyncTabButton"
                        Content="Синхронизация"
                        Style="{StaticResource GhostButton}"
                        MinWidth="130"
                        Click="AccountPanel_Click" />
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,8">
                <Border x:Name="AccountPanel"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16"
                        Margin="0,0,0,10"
                        Visibility="Collapsed">
                    <StackPanel MaxWidth="520" HorizontalAlignment="Left">
                        <TextBlock Text="Синхронизация с аккаунтом YummyAnime"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Нужно только если хотите отмечать просмотренные серии и избранное на сайте YummyAnime. Без входа WideS всё равно сохраняет историю локально на этом ПК." />
                        <TextBlock Margin="0,6,0,14"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Пароль не сохраняется. После входа WideS хранит только защищённый токен (DPAPI) для API." />

                        <TextBlock Text="E-mail аккаунта YummyAnime"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,4" />
                        <TextBox x:Name="LoginBox"
                                 MinHeight="38"
                                 Padding="10,8"
                                 Margin="0,0,0,10" />

                        <TextBlock Text="Пароль"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,4" />
                        <PasswordBox x:Name="PasswordBox"
                                     MinHeight="38"
                                     Padding="10,8"
                                     Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="LoginButton"
                                    Content="Войти и синхронизировать"
                                    Style="{StaticResource PrimaryButton}"
                                    MinWidth="210"
                                    Click="Login_Click" />
                            <Button x:Name="LogoutButton"
                                    Content="Выйти"
                                    Style="{StaticResource GhostButton}"
                                    Margin="8,0,0,0"
                                    MinWidth="90"
                                    Click="Logout_Click" />
                        </StackPanel>
                        <TextBlock x:Name="AccountHint"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <TextBlock x:Name="CatalogStatus"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </StackPanel>

            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="CatalogItems">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="156"
                                    Margin="0,0,12,14"
                                    Background="{StaticResource CardBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="CatalogItem_Click">
                                <StackPanel>
                                    <Grid Height="220">
                                        <Border Background="{StaticResource PanelBrush}"
                                                CornerRadius="8,8,0,0"
                                                ClipToBounds="True">
                                            <Image Source="{Binding PosterUrl}"
                                                   Stretch="UniformToFill"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                        </Border>
                                        <Button Content="★"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="6"
                                                Width="30"
                                                Height="30"
                                                Padding="0"
                                                Tag="{Binding}"
                                                Style="{StaticResource GhostButton}"
                                                Click="FavoriteButton_Click"
                                                ToolTip="В избранное" />
                                    </Grid>
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               MaxHeight="42"
                                               Margin="10,8,10,0" />
                                    <TextBlock Text="{Binding Subtitle}"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="12"
                                               Margin="10,4,10,10" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Grid x:Name="PlayerScreen" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="PlayerHeaderRow" Height="Auto" />
                <RowDefinition x:Name="PlayerControlsRow" Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Margin="0,0,0,10">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="← Каталог"
                            Style="{StaticResource GhostButton}"
                            Margin="0,0,8,0"
                            Click="BackToCatalog_Click" />
                    <Button x:Name="FavoriteToggleButton"
                            Content="☆"
                            Style="{StaticResource GhostButton}"
                            Width="38"
                            ToolTip="Избранное"
                            Click="FavoriteToggleButton_Click" />
                </StackPanel>
                <TextBlock x:Name="PlayerStatus"
                           DockPanel.Dock="Right"
                           Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
                <TextBlock x:Name="SelectedAnimeTitle"
                           Text="Аниме"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Озвучка" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                    <ComboBox x:Name="DubbingBox"
                              Margin="0,4,0,0"
                              MinHeight="36"
                              SelectionChanged="DubbingBox_SelectionChanged" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Плеер" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                    <ComboBox x:Name="PlayerBox"
                              Margin="0,4,0,0"
                              MinHeight="36"
                              SelectionChanged="PlayerBox_SelectionChanged" />
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Серия" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                    <ComboBox x:Name="EpisodeBox"
                              Margin="0,4,0,0"
                              MinHeight="36"
                              SelectionChanged="EpisodeBox_SelectionChanged" />
                </StackPanel>
            </Grid>

            <Border x:Name="PlayerFrame"
                    Grid.Row="2"
                    Background="#FF000000"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True">
                <Grid>
                    <wv2:WebView2 x:Name="Browser" />
                    <Border x:Name="LoadingPanel" Background="#FF101216" Padding="24">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="LoadingTitle"
                                       Text="Плеер готов"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="LoadingText"
                                       Text="Выберите серию"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <TextBlock x:Name="LoginStatus"
                   VerticalAlignment="Bottom"
                   Foreground="{StaticResource MutedBrush}"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,4" />
    </Grid>
</UserControl>
