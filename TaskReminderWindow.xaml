<Window x:Class="DevCockpit.TaskReminderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Напоминание"
        Icon="Assets/WideS.ico"
        Width="430"
        Height="250"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent">
    <Border BorderBrush="#2A323D" BorderThickness="1" CornerRadius="12" Background="{StaticResource AppBgBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
                <RowDefinition Height="56" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource SidebarBrush}"
                    CornerRadius="11,11,0,0"
                    BorderBrush="#1E242C" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Напоминание" Foreground="{StaticResource TextBrush}"
                           FontWeight="SemiBold" FontSize="14"
                           VerticalAlignment="Center" Margin="18,0,0,0" />
            </Border>

            <StackPanel Grid.Row="1" Margin="18,12,18,0">
                <TextBlock x:Name="TitleText" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" />
                <TextBlock x:Name="DescriptionText" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,10,0,0" MaxHeight="86" />
                <ListBox x:Name="SnoozeList"
                         Visibility="Collapsed"
                         Height="96"
                         Background="#1A1F27"
                         BorderBrush="#3C4653"
                         BorderThickness="1"
                         Margin="0,8,0,0" />
            </StackPanel>

            <Border Grid.Row="2" Background="{StaticResource SidebarBrush}"
                    CornerRadius="0,0,11,11"
                    BorderBrush="#1E242C" BorderThickness="0,1,0,0">
                <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button Content="Приступить" Style="{StaticResource PrimaryButton}" Click="Start_Click" />
                    <Button Content="Отложить" Style="{StaticResource GhostButton}" Click="Snooze_Click" />
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
</Window>
