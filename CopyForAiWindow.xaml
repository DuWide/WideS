<Window x:Class="DevCockpit.CopyForAiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Скопировать в AI"
        Icon="Assets/WideS.ico"
        Width="900"
        Height="720"
        MinWidth="760"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent">
    <Border BorderBrush="#2A323D" BorderThickness="1" CornerRadius="12" Background="{StaticResource AppBgBrush}">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="56" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource SidebarBrush}"
                    CornerRadius="11,11,0,0" BorderBrush="#1E242C" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right" Content="✕" Width="42" Height="42" Padding="0"
                            Foreground="{StaticResource MutedBrush}" FontSize="14" Cursor="Hand" Click="Cancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" Width="42" Height="42" CornerRadius="0,11,0,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#C42B1C" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="Скопировать в AI" Foreground="{StaticResource TextBrush}"
                               FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" Margin="18,0,0,0" />
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Padding="20,14,20,8">
                <StackPanel>
                    <TextBlock Text="Задача для AI" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="TaskBox" AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="72" MaxHeight="120" VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Padding="20,0,20,8">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Text="Заметки проекта" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <ListBox x:Name="NotesList" BorderBrush="#2A323D" Background="{StaticResource PanelBrush}" />
                </DockPanel>
            </Border>

            <Border Grid.Row="3" Padding="20,0,20,8">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Файлы (до 5, по 100 KB)" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                        <Button x:Name="AddFilesButton" Content="Добавить файлы..." Margin="12,0,0,0"
                                Padding="10,4" Cursor="Hand" Click="AddFiles_Click" />
                    </StackPanel>
                    <ListBox x:Name="FilesList" BorderBrush="#2A323D" Background="{StaticResource PanelBrush}" />
                </DockPanel>
            </Border>

            <Border Grid.Row="4" Padding="20,4,20,8">
                <TextBlock x:Name="SizeLabel" Foreground="{StaticResource AccentBrush}" FontSize="12" />
            </Border>

            <Border Grid.Row="5" Background="{StaticResource SidebarBrush}" CornerRadius="0,0,11,11"
                    BorderBrush="#1E242C" BorderThickness="0,1,0,0" Padding="16,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CopyButton" Content="Скопировать" MinWidth="130" Margin="0,0,8,0"
                            Style="{StaticResource PrimaryButton}" Click="Copy_Click" />
                    <Button x:Name="SaveButton" Content="Сохранить в файл" MinWidth="140" Margin="0,0,8,0"
                            Style="{StaticResource GhostButton}" Click="Save_Click" />
                    <Button Content="Отмена" MinWidth="90" Style="{StaticResource GhostButton}" Click="Cancel_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
