<Window x:Class="DevCockpit.ConnectionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подключение"
        Icon="Assets/WideS.ico"
        Width="720"
        Height="540"
        MinWidth="620"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent">
    <Border BorderBrush="#2A323D" BorderThickness="1" CornerRadius="12" Background="{StaticResource AppBgBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
                <RowDefinition Height="56" />
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <Border Grid.Row="0" Background="{StaticResource SidebarBrush}"
                    CornerRadius="11,11,0,0"
                    BorderBrush="#1E242C" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right" Content="✕"
                            Width="42" Height="42" Padding="0"
                            Foreground="{StaticResource MutedBrush}"
                            FontSize="14" Cursor="Hand" Click="Cancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" Width="42" Height="42" CornerRadius="0,11,0,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#C42B1C" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="Подключение" Foreground="{StaticResource TextBrush}"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center" Margin="18,0,0,0" />
                </DockPanel>
            </Border>

            <!-- Поля -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16,24,0">
                <StackPanel>
                    <!-- Название, Тип, Проект -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="160" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Название" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="NameBox" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="Тип" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                            <ComboBox x:Name="TypeBox" IsEditable="False" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Проект" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                            <ComboBox x:Name="WorkspaceBox" IsEditable="False" />
                        </StackPanel>
                    </Grid>

                    <!-- Адрес и Логин -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Адрес / AnyDesk ID" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="AddressBox" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Логин" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="LoginBox" />
                        </StackPanel>
                    </Grid>

                    <!-- Пароль + подсказка -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Пароль" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                            <TextBox x:Name="PasswordBox" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Foreground="{StaticResource MutedBrush}" FontSize="12"
                                   TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,16,0,0"
                                   Text="AnyDesk — запуск по ID, пароль копируется отдельно.&#10;RDP — через mstsc, логин/пароль вручную." />
                    </Grid>

                    <!-- Комментарий -->
                    <TextBlock Text="Комментарий" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="CommentBox" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" MinHeight="90" />
                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки -->
            <Border Grid.Row="2" Background="{StaticResource SidebarBrush}"
                    CornerRadius="0,0,11,11"
                    BorderBrush="#1E242C" BorderThickness="0,1,0,0">
                <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Click="Save_Click" />
                    <Button Content="Отмена"    Style="{StaticResource GhostButton}"   Click="Cancel_Click" />
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
</Window>
