<Window x:Class="DevCockpit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WideS"
        Icon="Assets/WideS.ico"
        Width="1280"
        Height="820"
        MinWidth="1080"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent">
    <Border Background="{DynamicResource AppBgBrush}" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- TITLEBAR -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SidebarBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="11,11,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Image Source="Assets/WideS.png" Width="20" Height="20" Margin="0,0,8,0" />
                        <TextBlock Text="WideS" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Button x:Name="MinimizeButton" Width="38" Height="28" Style="{StaticResource WindowButton}" Click="Minimize_Click" />
                        <Button x:Name="MaximizeButton" Width="38" Height="28" Style="{StaticResource WindowButton}" Click="Maximize_Click" />
                        <Button x:Name="CloseButton" Width="38" Height="28" Margin="2,0,0,0" Style="{StaticResource WindowButton}" Click="CloseWindow_Click" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- MAIN AREA -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SidebarBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid Margin="10,14,10,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <StackPanel x:Name="NavPanel" />
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Row="1">
                            <Border x:Name="NowPlayingPanel" Background="{DynamicResource AccentSoftBgBrush}" BorderBrush="{DynamicResource AccentBorderBrush}" BorderThickness="1"
                                    CornerRadius="10" Padding="10,9" Margin="0,0,0,8" Visibility="Collapsed">
                                <DockPanel LastChildFill="True">
                                    <Image x:Name="NpAlbumArt" DockPanel.Dock="Left" Width="44" Height="44"
                                           Margin="0,0,10,0" Stretch="UniformToFill" Visibility="Collapsed" />
                                    <StackPanel x:Name="NpContentPanel">
                                    <StackPanel x:Name="NpSourceRow" Orientation="Horizontal" Margin="0,0,0,7">
                                        <Border Width="6" Height="6" CornerRadius="3" Background="{StaticResource AccentBrush}"
                                                VerticalAlignment="Center" Margin="0,0,7,0" />
                                        <TextBlock x:Name="NpSource" Text="Сейчас играет" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock x:Name="NpTitle" Text="" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="NpArtist" Text="" FontSize="10"
                                               Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis"
                                               Margin="0,1,0,8" />
                                    <StackPanel x:Name="NpControls" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button x:Name="NpPrev" Width="30" Height="28" Style="{StaticResource WindowButton}"
                                                Margin="0,0,6,0" ToolTip="Предыдущий" Click="NpPrev_Click" />
                                        <Button x:Name="NpPlay" Width="38" Height="28" Style="{StaticResource WindowButton}"
                                                ToolTip="Пауза / Играть" Click="NpPlay_Click" />
                                        <Button x:Name="NpNext" Width="30" Height="28" Style="{StaticResource WindowButton}"
                                                Margin="6,0,0,0" ToolTip="Следующий" Click="NpNext_Click" />
                                    </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <Border x:Name="SidebarFooterPanel" Background="{DynamicResource SidebarFooterBgBrush}" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="10,8" Margin="0,0,0,4">
                                <TextBlock Text="local · DPAPI secrets" FontSize="10"
                                           Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- RIGHT CONTENT -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource AppBgBrush}" Padding="22,14,22,12"
                            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                <Button x:Name="BackButton" Width="32" Height="30" Style="{StaticResource GhostButton}" ToolTip="Назад" Click="Back_Click" />
                                <Button x:Name="ForwardButton" Width="32" Height="30" Style="{StaticResource GhostButton}" ToolTip="Вперёд" Click="Forward_Click" Margin="4,0,0,0" />
                            </StackPanel>
                            <StackPanel x:Name="TopNavPanel" DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" />
                            <Border x:Name="ActiveTaskPill"
                                    DockPanel.Dock="Right"
                                    Visibility="Collapsed"
                                    Background="{DynamicResource AccentSoftBgBrush}"
                                    BorderBrush="{DynamicResource AccentBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="10,4"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="ActiveTaskPill_Click">
                                <TextBlock x:Name="ActiveTaskPillText"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="260" />
                            </Border>
                            <ComboBox x:Name="ProjectSwitcher"
                                      DockPanel.Dock="Right"
                                      Width="220"
                                      Margin="0,0,12,0"
                                      VerticalAlignment="Center"
                                      IsEditable="False"
                                      SelectionChanged="ProjectSwitcher_SelectionChanged" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="PageTitle" Text="Главная" FontSize="20" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="PageSubtitle" Text="" FontSize="12"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,3,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Background="{DynamicResource AppBgBrush}"
                                  Padding="22,4,22,4">
                        <StackPanel x:Name="TabsPanel" Orientation="Horizontal" />
                    </ScrollViewer>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="22,12,22,12">
                        <ContentControl x:Name="ContentHost" />
                    </ScrollViewer>

                    <Border x:Name="LogPanel"
                            Grid.Row="3"
                            Background="{DynamicResource LogPanelBgBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="22,7"
                            Height="38"
                            CornerRadius="0,0,11,11"
                            Cursor="Hand"
                            MouseEnter="LogPanel_MouseEnter"
                            MouseLeave="LogPanel_MouseLeave"
                            MouseLeftButtonUp="LogPanel_MouseLeftButtonUp">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Журнал" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" Margin="0,0,10,0" />
                                <Border x:Name="LogBadge" Background="{StaticResource AccentSoftBgBrush}" BorderBrush="{StaticResource AccentBorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="6,1" Margin="0,0,10,0" Visibility="Collapsed">
                                    <TextBlock x:Name="LogBadgeText" FontSize="10" Foreground="{StaticResource AccentBrush}" />
                                </Border>
                            </StackPanel>
                            <TextBlock x:Name="LogPreview" DockPanel.Dock="Left" FontFamily="Consolas" FontSize="11"
                                       Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" MaxWidth="900" />
                            <TextBox x:Name="LogBox" IsReadOnly="True" BorderThickness="0"
                                     Background="Transparent" FontFamily="Consolas" FontSize="12"
                                     VerticalScrollBarVisibility="Auto" Visibility="Collapsed" />
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
