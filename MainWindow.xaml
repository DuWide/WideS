<Window x:Class="DevCockpit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="WideS"
        Icon="Assets/WideS.ico"
        Width="1360"
        Height="860"
        MinWidth="1040"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBgBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="8" GlassFrameThickness="0" ResizeBorderThickness="6" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Border Background="{DynamicResource AppBgBrush}" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- TITLEBAR -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SidebarBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="7,7,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Image Source="Assets/WideS.png" Width="18" Height="18" Margin="0,0,8,0" />
                        <TextBlock Text="WideS" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Button x:Name="MinimizeButton" AutomationProperties.Name="Свернуть" Width="40" Height="30" Style="{StaticResource WindowButton}" Click="Minimize_Click" />
                        <Button x:Name="MaximizeButton" AutomationProperties.Name="Развернуть" Width="40" Height="30" Style="{StaticResource WindowButton}" Click="Maximize_Click" />
                        <Button x:Name="CloseButton" AutomationProperties.Name="Скрыть в трей" Width="40" Height="30" Margin="2,0,0,0" Style="{StaticResource DialogCloseButton}" Click="CloseWindow_Click" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- MAIN AREA -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SidebarBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid Margin="12,14,12,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <StackPanel x:Name="NavPanel" />
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Row="1">
                            <Border x:Name="NowPlayingPanel" Background="{DynamicResource AccentSoftBgBrush}" BorderBrush="{DynamicResource AccentBorderBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="10" Margin="0,0,0,8" Visibility="Collapsed">
                                <DockPanel LastChildFill="True">
                                    <Image x:Name="NpAlbumArt" DockPanel.Dock="Left" Width="44" Height="44"
                                           Margin="0,0,10,0" Stretch="UniformToFill" Visibility="Collapsed" />
                                    <StackPanel x:Name="NpContentPanel">
                                    <StackPanel x:Name="NpSourceRow" Orientation="Horizontal" Margin="0,0,0,7">
                                        <Border Width="6" Height="6" CornerRadius="3" Background="{StaticResource AccentBrush}"
                                                VerticalAlignment="Center" Margin="0,0,7,0" />
                                        <TextBlock x:Name="NpSource" Text="Сейчас играет" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock x:Name="NpTitle" Text="" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="NpArtist" Text="" FontSize="10"
                                               Foreground="{DynamicResource MutedBrush}" TextTrimming="CharacterEllipsis"
                                               Margin="0,1,0,8" />
                                    <StackPanel x:Name="NpControls" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button x:Name="NpPrev" Width="30" Height="28" Style="{StaticResource WindowButton}"
                                                Margin="0,0,6,0" ToolTip="Предыдущий" Click="NpPrev_Click" />
                                        <Button x:Name="NpPlay" Width="38" Height="28" Style="{StaticResource WindowButton}"
                                                ToolTip="Пауза / Играть" Click="NpPlay_Click" />
                                        <Button x:Name="NpNext" Width="30" Height="28" Style="{StaticResource WindowButton}"
                                                Margin="6,0,0,0" ToolTip="Следующий" Click="NpNext_Click" />
                                    </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <Border x:Name="SidebarFooterPanel" Background="{DynamicResource SidebarFooterBgBrush}" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="10,7" Margin="0,0,0,2">
                                <TextBlock Text="Локально · защищено DPAPI" FontSize="10"
                                           Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- RIGHT CONTENT -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource AppBgBrush}" Padding="24,18,24,16"
                            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                <Button x:Name="BackButton" AutomationProperties.Name="Назад" Width="32" Height="32" Style="{StaticResource GhostButton}" ToolTip="Назад" Click="Back_Click" />
                                <Button x:Name="ForwardButton" AutomationProperties.Name="Вперёд" Width="32" Height="32" Style="{StaticResource GhostButton}" ToolTip="Вперёд" Click="Forward_Click" Margin="4,0,0,0" />
                            </StackPanel>
                            <Border x:Name="ActiveTaskPill"
                                    DockPanel.Dock="Right"
                                    Visibility="Collapsed"
                                    Background="{DynamicResource AccentSoftBgBrush}"
                                    BorderBrush="{DynamicResource AccentBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,5"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="ActiveTaskPill_Click">
                                <TextBlock x:Name="ActiveTaskPillText"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="260" />
                            </Border>
                            <ComboBox x:Name="ProjectSwitcher"
                                      DockPanel.Dock="Right"
                                      Width="240"
                                      Margin="0,0,12,0"
                                      VerticalAlignment="Center"
                                      IsEditable="False"
                                      SelectionChanged="ProjectSwitcher_SelectionChanged" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="PageTitle" Text="Главная" Style="{StaticResource PageTitleText}" />
                                <TextBlock x:Name="PageSubtitle" Text="" FontSize="12"
                                           Foreground="{DynamicResource MutedBrush}" Margin="0,3,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="24,8">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="GlobalSearchButton" AutomationProperties.Name="Поиск" Width="32" Height="32" Style="{StaticResource GhostButton}"
                                        ToolTip="Поиск (Ctrl+K)" Click="GlobalSearch_Click" />
                                <Button x:Name="DockToggleButton" AutomationProperties.Name="Плавающая панель" Width="32" Height="32" Margin="6,0,0,0" Style="{StaticResource GhostButton}"
                                        ToolTip="Floating Dock (Ctrl+Alt+Space)" Click="DockToggle_Click" />
                            </StackPanel>
                            <StackPanel x:Name="TopNavPanel" Orientation="Horizontal" VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Background="{DynamicResource AppBgBrush}"
                                  Padding="24,5,24,3">
                        <StackPanel x:Name="TabsPanel" Orientation="Horizontal" />
                    </ScrollViewer>

                    <ScrollViewer x:Name="ContentScrollViewer" Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="24,16,24,18">
                        <ContentControl x:Name="ContentHost" />
                    </ScrollViewer>

                    <Border x:Name="LogPanel"
                            Grid.Row="4"
                            Background="{DynamicResource LogPanelBgBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="24,7"
                            Height="36"
                            CornerRadius="0,0,7,7"
                            Cursor="Hand"
                            MouseEnter="LogPanel_MouseEnter"
                            MouseLeave="LogPanel_MouseLeave"
                            MouseLeftButtonUp="LogPanel_MouseLeftButtonUp">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Журнал" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedBrush}" Margin="0,0,10,0" />
                                <Border x:Name="LogBadge" Background="{StaticResource AccentSoftBgBrush}" BorderBrush="{StaticResource AccentBorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="6,1" Margin="0,0,10,0" Visibility="Collapsed">
                                    <TextBlock x:Name="LogBadgeText" FontSize="10" Foreground="{StaticResource AccentBrush}" />
                                </Border>
                            </StackPanel>
                            <TextBlock x:Name="LogPreview" DockPanel.Dock="Left" FontFamily="Consolas" FontSize="11"
                                       Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" MaxWidth="900" />
                            <TextBox x:Name="LogBox" IsReadOnly="True" BorderThickness="0"
                                     Background="Transparent" FontFamily="{StaticResource MonoFont}" FontSize="12"
                                     VerticalScrollBarVisibility="Auto" Visibility="Collapsed" />
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
