<Window x:Class="DevCockpit.ConnectionPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пароль подключения"
        Icon="Assets/WideS.ico"
        Width="420"
        Height="220"
        MinWidth="380"
        MinHeight="200"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent">
    <Border BorderBrush="#2A323D" BorderThickness="1" CornerRadius="12" Background="{StaticResource AppBgBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
                <RowDefinition Height="56" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource SidebarBrush}"
                    CornerRadius="11,11,0,0"
                    BorderBrush="#1E242C" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right" Content="✕"
                            Width="42" Height="42" Padding="0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource MutedBrush}"
                            FontSize="14" Cursor="Hand"
                            Click="Close_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" Width="42" Height="42" CornerRadius="0,11,0,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#C42B1C" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock x:Name="TitleText" Text="Пароль" Foreground="{StaticResource TextBrush}"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center" Margin="18,0,0,0" />
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,16,24,0">
                <TextBlock Text="Пароль для копирования" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8" />
                <TextBox x:Name="PasswordBox" IsReadOnly="True" FontSize="16" Padding="10" />
            </StackPanel>

            <Border Grid.Row="2" Background="{StaticResource SidebarBrush}"
                    CornerRadius="0,0,11,11"
                    BorderBrush="#1E242C" BorderThickness="0,1,0,0">
                <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button Content="Копировать" Style="{StaticResource PrimaryButton}" Click="Copy_Click" />
                    <Button Content="Закрыть" Style="{StaticResource GhostButton}" Click="Close_Click" />
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
</Window>
