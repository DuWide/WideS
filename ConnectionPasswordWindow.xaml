<Window x:Class="DevCockpit.ConnectionPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пароль подключения"
        Icon="Assets/WideS.ico"
        Width="420"
        Height="220"
        MinWidth="380"
        MinHeight="200"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent">
    <Border Style="{StaticResource DialogFrame}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
                <RowDefinition Height="56" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource DialogHeader}"
                    CornerRadius="7,7,0,0"
                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right" Style="{StaticResource DialogCloseButton}" Click="Close_Click"><Path Data="{StaticResource CloseIconGeometry}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="13" Height="13" Stretch="Uniform" /></Button>
                    <TextBlock x:Name="TitleText" Text="Пароль" Foreground="{StaticResource TextBrush}"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center" Margin="18,0,0,0" />
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,16,24,0">
                <TextBlock Text="Пароль для копирования" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8" />
                <TextBox x:Name="PasswordBox" IsReadOnly="True" FontSize="16" Padding="10" />
            </StackPanel>

            <Border Grid.Row="2" Style="{StaticResource DialogFooter}"
                    CornerRadius="0,0,7,7"
                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
                <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button Content="Копировать" Style="{StaticResource PrimaryButton}" Click="Copy_Click" />
                    <Button Content="Закрыть" Style="{StaticResource GhostButton}" Click="Close_Click" />
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
</Window>
